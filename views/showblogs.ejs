<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blogging App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>

       <%- include("./partials/navbar") %>

     <div class="container mt-5">

    <div class="mx-auto" style="max-width: 850px;">

        <h1 class="fw-bold mb-4 text-center">
            <%= blog.title %>
        </h1>

        <div class="text-center text-muted mb-4">
            Written by <strong><%= blog.createdby?.name || "Anonymous" %></strong>
        </div>

        <div class="text-center mb-5">
            <img
                src="<%= blog.coverimageurl %>"
                class="img-fluid rounded shadow"
                style="max-height: 500px; width: 100%; object-fit: cover;"
                alt="Blog Cover"
            >
        </div>

        <!-- Blog Content -->
        <div
            class="fs-5"
            style="
                line-height: 1.9;
                text-align: justify;
                white-space: pre-wrap;
            "
        >
            <%= blog.body %>
        </div>

    </div>

</div>
        
      
       <div container mt-5>

        <form action="/blog/comment/<%=blog._id%>" method="POST" >

        <div class="mb-3 ms-3">
     <label for="text" class="form-label" >Add comments on this blog</label>
     <input type="text" class="form-control" id="content" name="content" aria-describedby="emailHelp">
      </div>

        <button type="submit" class="btn btn-secondary ms-3">submit</button>
       </div>
        
          </form>
        </div>

       <% if(locals.comment){ %>

        <div class="container mt-5">

    <div class="mx-auto" style="max-width:850px">

        <h3 class="mb-4">
            Comments (<%= comment.length %>)
        </h3>

        <% if(comment.length > 0) { %>

            <% comment.forEach(c => { %>

                <div class="card mb-3 shadow-sm border-0">
                    <div class="card-body">

                        <div class="d-flex align-items-center">

                            <!-- Profile Image -->
                            <img
                                src="<%= c.commentedbyuser.profileimageurl%>"
                                alt="profile"
                                class="rounded-circle me-3"
                                width="50"
                                height="50"
                                style="object-fit: cover;"
                            >

                            <div>
                                <h6 class="mb-1 fw-bold">
                                    <%= c.commentedbyuser.name %>
                                </h6>

                                <small class="text-muted">
                                    Reader
                                </small>
                            </div>

                        </div>

                        <hr>

                        <p
                            class="mb-0"
                            style="white-space: pre-wrap;"
                        >
                            <%= c.content %>
                        </p>

                    </div>
                </div>

            <% }) %>

        <% } else { %>

            <div class="alert alert-light border">
                No comments yet. Be the first to comment!
            </div>

        <% } %>

    </div>

</div>

       <% } %>
        
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>