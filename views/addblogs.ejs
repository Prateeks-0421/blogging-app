<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blogging App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>

       <%- include("./partials/navbar") %>

       <div container mt-3 >


      <form action="/blog" method="post"  enctype="multipart/form-data" >

      <div class="mb-3 ms-3">
    <label for="file" class="form-label" >cover image</label>
    <input type="file" class="form-control" id="coverimage" name="coverimage" aria-describedby="emailHelp">
      </div>

    <div class="mb-3 ms-3">
    <label for="title" class="form-label" >title</label>
    <input type="text" class="form-control" id="title" name="title" aria-describedby="emailHelp">
      </div>

       
      <div class="mb-3 ms-3">
    <label for="body" class="form-label" >body</label>
      <textarea class="form-control" placeholder="Leave a comment here" id="body" name="body"></textarea>
      </div>
      <div class="mb-3 ms-3">
       <button type="submit" class="btn btn-secondary">submit</button>
    </div>

      </form>


       </div>


    
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>